# Copy to .env and fill in. All values are optional except OPENAI_API_KEY.

# Required: OpenAI API key (provider for all LLM agents via LiteLLM).
OPENAI_API_KEY=sk-...

# Model routing (LiteLLM "openai/<model>" strings). Override any of these.
# Correctness-critical document intelligence uses the strongest model.
EXTRACTION_MODEL=openai/gpt-5
VALIDATION_MODEL=openai/gpt-5
SANITY_CHECK_MODEL=openai/gpt-5
# Lighter prose tasks (summaries, explanations, help chat) use the mini model.
ORCHESTRATION_MODEL=openai/gpt-5-mini
CHAT_MODEL=openai/gpt-5-mini

# Reasoning effort hint for reasoning-capable models.
EXTRACTION_REASONING_EFFORT=high

# Document self-critique loop bound.
MAX_EXTRACTION_RETRIES=2

# Assessment / financial year context.
ASSESSMENT_YEAR=2026-27
FINANCIAL_YEAR=2025-26

# CORS origins for the frontend (JSON list).
# CORS_ORIGINS=["http://localhost:3000"]
