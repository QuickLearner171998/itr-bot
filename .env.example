# Copy to .env and fill in values. Never commit .env.

# --- Backend (required) ---
OPENAI_API_KEY=sk-...

# --- Backend (optional overrides) ---
# DATA_DIR=/tmp/itr_bot          # default on Render free tier
# LOG_LEVEL=INFO
# CORS_ORIGINS=https://your-app.vercel.app

# --- Frontend (set in Vercel dashboard as environment variable) ---
# NEXT_PUBLIC_API_BASE=https://itr-bot-backend.onrender.com
